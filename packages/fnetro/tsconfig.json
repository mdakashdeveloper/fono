{
  "compilerOptions": {
    "target":                     "ES2022",
    "module":                     "ESNext",
    "moduleResolution":           "bundler",
    "lib":                        ["ES2022", "DOM"],
    "types":                      ["node"],
    "jsx":                        "preserve",
    "jsxImportSource":            "solid-js",
    "strict":                     true,
    "skipLibCheck":               true,
    "noEmit":                     true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule":          true,
    "isolatedModules":            true,
    "verbatimModuleSyntax":       true,
    "declaration":                false
  },
  "include": ["*.ts", "*.tsx"],
  "exclude": ["node_modules", "dist"]
}
